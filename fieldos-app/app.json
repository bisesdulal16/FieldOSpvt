{
  "expo": {
    "name": "FieldOS Nepal",
    "slug": "fieldos-nepal",
    "version": "2.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B1B3A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "np.fieldos.app",
      "infoPlist": {
        "NSCameraUsageDescription": "FieldOS needs the camera for face clock-in."
      }
    },
    "android": {
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0B1B3A"
      },
      "package": "np.fieldos.app",
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "FieldOS needs camera access for face verification."
        }
      ],
      [
        "expo-location",
        {
          "locationPermission": "FieldOS needs location access for visit check-ins."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "enableFrameProcessors": true,
          "cameraPermissionText": "FieldOS needs the camera for face clock-in.",
          "enableMicrophonePermission": false
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "FieldOS needs the microphone to record voice notes."
        }
      ],
      "expo-llm-mediapipe",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 26,
            "usesCleartextTraffic": true,
            "buildArchs": [
              "arm64-v8a"
            ]
          }
        }
      ],
      "expo-router"
    ],
    "scheme": "fieldos-nepal",
    "extra": {
      "eas": {
        "projectId": "24b312d2-0f5c-4d91-bf67-e3c7a34ff221"
      }
    },
    "owner": "bisesdulal16"
  }
}
