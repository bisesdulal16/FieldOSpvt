{
  "cli": {
    "version": ">= 5.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.fieldosnepal.tech",
        "EXPO_PUBLIC_ENABLE_MOCK_SYNC": "false",
        "EXPO_PUBLIC_FACE_MODEL_URL": "https://api.fieldosnepal.tech/static/mobilefacenet.tflite",
        "EXPO_PUBLIC_FACE_THRESHOLD": "0.62"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
