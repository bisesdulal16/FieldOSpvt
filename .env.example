# FieldOS Nepal — container stack config. Copy to .env and fill in real values.
# DO NOT commit .env (it's gitignored).

# ── Database ───────────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_db_password

# ── Backend security ───────────────────────────────────────────────
# Generate:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change_me_generate_a_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
APP_ENV=production
# Comma-separated allowed origins for the mobile app / dashboard. '*' is fine for a
# closed pilot; lock it to your dashboard URL for production.
CORS_ORIGINS=*

# ── White-label branding (rebrands the same build per institution) ─
ORG_NAME=FieldOS
ORG_TAGLINE=Nepal
ORG_PRODUCT_SUFFIX=Branch Manager Dashboard
ORG_PRIMARY_COLOR=#0B1B3A
ORG_ACCENT_COLOR=#F59E0B
ORG_LOGO_URL=

# ── Dashboard ──────────────────────────────────────────────────────
NEXT_PUBLIC_PILOT_MODE=true

# ── Production TLS (docker-compose.prod.yml: nginx + Let's Encrypt) ─
# Two public hostnames whose DNS A-records point at this server.
#   API_DOMAIN  -> mobile app + dashboard proxy target (backend)
#   DASH_DOMAIN -> manager dashboard
API_DOMAIN=api.yourorg.com.np
DASH_DOMAIN=dash.yourorg.com.np
# Email Let's Encrypt uses for expiry warnings.
LETSENCRYPT_EMAIL=ops@yourorg.com.np
# With TLS in front, lock CORS to the dashboard origin (override the '*' above):
#   CORS_ORIGINS=https://dash.yourorg.com.np

# ── SMS anti-fraud receipts ────────────────────────────────────────
# 'log' = no gateway (dev/demo); 'sparrow' = Nepal prod (set SMS_API_TOKEN).
SMS_PROVIDER=log
SMS_API_TOKEN=

# ── On-prem AI (only used when you run `docker compose --profile ai up`) ──
# When the AI profile is down, voice transcription returns empty (officer types)
# and AI cleanup/summary falls back to heuristics — nothing hard-fails.
WHISPER_URL=http://whisper:8000/v1/audio/transcriptions
WHISPER_MODEL=Systran/faster-whisper-small
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=gemma2:2b

# ── Error monitoring (optional) ────────────────────────────────────
SENTRY_DSN=

# ── Mobile app ─────────────────────────────────────────────────────
# The Expo app does NOT read this file. Set EXPO_PUBLIC_API_URL in
# fieldos-app/eas.json to the VM's reachable URL, e.g.:
#   http://<vm-lan-ip>:8000/api/v1   (or your Tailscale/Cloudflare hostname)
