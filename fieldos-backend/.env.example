# FieldOS Nepal Backend — copy to .env and fill in real values. DO NOT commit .env.
APP_ENV=development
DB_TYPE=sqlite
SQLITE_PATH=./fieldos_nepal.db
# Generate a real 64-char secret for pilot/production:  python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=*

# White-label branding (optional — rebrands the same build per institution)
ORG_NAME=FieldOS
ORG_NAME_NE=फिल्डओएस
ORG_TAGLINE=Nepal
ORG_PRODUCT_SUFFIX=Branch Manager Dashboard
ORG_PRIMARY_COLOR=#0B1B3A
ORG_ACCENT_COLOR=#F59E0B
ORG_LOGO_URL=

# ── Production: hosted Postgres (e.g. Neon free tier) ──────────────────
# DB_TYPE=postgres
# DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DB?ssl=require
